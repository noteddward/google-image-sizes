{
  "manifest_version": 3,
  "name": "Google Image Sizes",
  "version": "1.0.1",
  "description": "Adds Megapixel filters to Google Image Tools -> Size.",
  "homepage_url": "https://github.com/noteddward/google-image-sizes",
  "icons": {
    "512": "icon.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.google.com/search?*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/search?*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}